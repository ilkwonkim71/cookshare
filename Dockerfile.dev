# 개발용 이미지 — pnpm 모노레포 (backend/frontend/shared) 공용
# 핫 리로드는 compose에서 소스 바인드 마운트로 처리. node_modules는 이미지 내부 Linux 빌드를 사용.
FROM node:22-bookworm-slim

# better-sqlite3 등 네이티브 모듈 빌드 대비(프리빌트 실패 시 폴백) + corepack
RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 make g++ ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Docker 빌드 중에는 git 훅 설치(husky) 비활성화 (.git 없음)
ENV HUSKY=0
ENV NODE_ENV=development

# pnpm 활성화 + 버전 고정(packageManager와 일치)
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

WORKDIR /app

# 1) 매니페스트만 먼저 복사 → 의존성 레이어 캐시 최적화
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY backend/package.json ./backend/package.json
COPY frontend/package.json ./frontend/package.json
COPY packages/shared/package.json ./packages/shared/package.json

# 2) 워크스페이스 전체 설치 (Linux 네이티브 바이너리: better-sqlite3, esbuild)
RUN pnpm install --frozen-lockfile

# 3) 나머지 소스 복사 후 공유 패키지 빌드(backend/frontend가 dist를 참조)
COPY . .
RUN pnpm --filter @cookshare/shared run build

EXPOSE 3000 4000

# 단일 컨테이너로 띄울 때의 기본 명령(보통 compose가 서비스별로 override)
CMD ["pnpm", "-r", "--parallel", "run", "dev"]
