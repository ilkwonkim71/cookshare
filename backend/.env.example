PORT=4000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
# Postgres 연결 문자열 (Supabase 등). 로컬은 docker-compose 의 postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cookshare
# 관리형 Postgres(Supabase 등)는 SSL 필요 시 true
DATABASE_SSL=false
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
